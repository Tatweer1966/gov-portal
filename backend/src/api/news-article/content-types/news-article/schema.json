{
  "kind": "collectionType",
  "collectionName": "news_articles",
  "info": {
    "singularName": "news-article",
    "pluralName": "news-articles",
    "displayName": "News Article"
  },
  "options": {
    "draftAndPublish": true
  },
  "attributes": {
    "title_ar": {
      "type": "string",
      "required": true
    },
    "title_en": {
      "type": "string"
    },
    "slug": {
      "type": "uid",
      "targetField": "title_ar",
      "required": true
    },
    "summary_ar": {
      "type": "text"
    },
    "summary_en": {
      "type": "text"
    },
    "content_ar": {
      "type": "richtext",
      "required": true
    },
    "content_en": {
      "type": "richtext"
    },
    "category": {
      "type": "string"
    },
    "priority": {
      "type": "integer",
      "default": 0
    },
    "is_featured": {
      "type": "boolean",
      "default": false
    },
    "published_at_custom": {
      "type": "datetime"
    },
    "featured_image": {
      "type": "media",
      "multiple": false,
      "allowedTypes": ["images"]
    },
    "gallery_images": {
      "type": "media",
      "multiple": true,
      "allowedTypes": ["images"]
    }
  }
}